---
import '../styles/global.css';
const { title = 'Automate Momentum - Cloud-Based AI Systems & Outreach' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header style="position: sticky; top: 0; z-index: 1000; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); border-bottom: 1px solid var(--color-border); padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center;">
			<div style="font-weight: 800; font-size: var(--text-xl); color: var(--color-text-main); letter-spacing: -0.02em;">
				Automate<span class="text-accent">Momentum</span>
			</div>
			<nav style="display: flex; gap: var(--space-md); align-items: center; font-size: var(--text-sm); font-weight: 500;">
				<a href="#services" style="color: var(--color-text-muted); text-decoration: none;">Services</a>
				<a href="#experience" style="color: var(--color-text-muted); text-decoration: none;">Experience</a>
				<a href="mailto:admin@automatemomentum.com" class="btn" style="padding: 0.5rem 1rem; font-size: var(--text-sm);">Contact Us</a>
			</nav>
		</header>

		<slot />

		<footer style="background-color: var(--color-secondary); padding: var(--space-xl) var(--space-md); text-align: center; border-top: 1px solid var(--color-border);">
			<div style="font-weight: 600; font-size: var(--text-lg); color: var(--color-text-main); margin-bottom: var(--space-sm);">
				Automate Momentum
			</div>
			<p style="font-size: var(--text-sm); max-width: 100%; margin-bottom: var(--space-md);">
				Engineering the Algorithmic Future.<br/>
				&copy; {new Date().getFullYear()} All rights reserved.
			</p>
			<div>
				<a href="https://www.linkedin.com/company/113349760" target="_blank" style="color: var(--color-accent); text-decoration: none; font-weight: 500;">LinkedIn Profile</a>
			</div>
		</footer>
	</body>
</html>
