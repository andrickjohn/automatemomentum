---
import '../styles/global.css';
const { title = 'Automate Momentum - We build sales systems for design agencies.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="glass-container" style="position: fixed; top: 0; width: 100%; z-index: 1000; padding: var(--space-sm) var(--space-md); display: flex; justify-content: space-between; align-items: center; border-radius: 0; border-top: none; border-left: none; border-right: none;">
			<div style="font-family: var(--font-mono); font-weight: bold; letter-spacing: 0.05em; font-size: var(--text-sm);">
				AUTOMATE <span class="text-accent glow-accent">MOMENTUM</span>
			</div>
			<nav style="display: flex; gap: var(--space-md); font-size: var(--text-sm);">
				<a href="#services" style="color: var(--color-text-main); text-decoration: none;">Services</a>
				<a href="#process" style="color: var(--color-text-main); text-decoration: none;">How It Works</a>
				<a href="https://calendly.com/andrickjohn-l0n9/30min" target="_blank" class="text-accent" style="text-decoration: none; font-weight: bold;">Let's Chat</a>
			</nav>
		</header>

		<slot />

		<footer style="padding: var(--space-xl) var(--space-md) var(--space-md); text-align: center; border-top: 1px solid rgba(255,255,255,0.05); margin-top: var(--space-2xl);">
			<div style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-text-muted);">
				Engineering the Algorithmic Future.<br/>
				&copy; {new Date().getFullYear()} Automate Momentum.
			</div>
		</footer>
	</body>
</html>
