---
import '../styles/global.css';
const { title = 'Automate Momentum - We build sales systems for design agencies.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header style="position: sticky; top: 0; z-index: 1000; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(8px); border-bottom: 1px solid var(--color-border); padding: 1.5rem 2rem; display: flex; justify-content: space-between; align-items: center;">
			<div style="font-weight: 800; font-size: var(--text-lg); color: var(--color-text-main); letter-spacing: -0.02em;">
				Automate Momentum
			</div>
			<nav style="display: flex; gap: var(--space-md); align-items: center; font-size: var(--text-sm); font-weight: 600;">
				<a href="#services" style="color: var(--color-text-muted); text-decoration: none;">Services</a>
				<a href="#process" style="color: var(--color-text-muted); text-decoration: none;">How It Works</a>
				<a href="#results" style="color: var(--color-text-muted); text-decoration: none;">Results</a>
				<a href="https://calendly.com/andrickjohn-l0n9/30min" target="_blank" class="btn" style="padding: 0.75rem 1.5rem; font-size: var(--text-sm);">Let's Chat</a>
			</nav>
		</header>

		<slot />

		<footer style="background-color: var(--color-secondary); padding: var(--space-xl) var(--space-md); text-align: center; border-top: 1px solid var(--color-border);">
			<div style="font-weight: 700; font-size: var(--text-xl); color: var(--color-text-main); margin-bottom: var(--space-sm);">
				Automate Momentum
			</div>
			<p style="font-size: var(--text-sm); max-width: 100%; margin: 0 auto var(--space-md) auto;">
				Effortless Business Growth &middot; Custom Solutions<br/>
				&copy; {new Date().getFullYear()} All rights reserved.
			</p>
			<div>
				<a href="https://automatemomentum.com" target="_blank" style="color: var(--color-accent); text-decoration: none; font-weight: 600;">Visit Live Site</a>
			</div>
		</footer>
	</body>
</html>
