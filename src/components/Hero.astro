<!-- Hero Section with Sovereign Container and Asymmetric layout -->
<section class="asymmetric-grid" style="min-height: 100vh; padding: var(--space-xl) var(--space-lg); align-items: center;">
  
  <div class="asymmetric-item left glass-container animate-fade-in delay-100">
    <div style="font-size: var(--text-sm); font-family: var(--font-mono); color: var(--color-text-muted); margin-bottom: var(--space-sm); letter-spacing: 0.1em; text-transform: uppercase;">
      Automate Momentum v2
    </div>
    
    <h1 style="font-size: var(--text-5xl); margin-bottom: var(--space-md);">
      Engineering the <br/>
      <span class="text-accent glow-accent">Algorithmic Future.</span>
    </h1>
    
    <p style="font-size: var(--text-lg); margin-bottom: var(--space-lg);">
      We build sovereign systems that obliterate administrative friction. Designed for scale. Optimized for acceleration.
    </p>

    <div>
      <a href="#explore" class="btn">Deploy Now</a>
    </div>
  </div>

  <div class="asymmetric-item right animate-fade-in delay-500" style="position: relative; display: flex; justify-content: center; align-items: center;">
    <!-- Abstract Visual Density Element -->
    <div style="position: absolute; width: 100%; height: 100%; background: radial-gradient(circle at center, rgba(79, 70, 229, 0.1) 0%, transparent 70%); z-index: 0;"></div>
    
    <img 
      src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4MDAiIGhlaWdodD0iODAwIj48cmVjdCB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDAlIiBmaWxsPSJ0cmFuc3BhcmVudCIvPjwvc3ZnPg==" 
      data-src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" 
      alt="Abstract Momentum Noir Visual" 
      style="max-width: 90%; height: auto; border: 1px solid rgba(255,255,255,0.05); border-radius: 2px; position: relative; z-index: 1;"
    />
  </div>

</section>
