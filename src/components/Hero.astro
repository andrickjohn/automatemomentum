<section class="asymmetric-grid" style="min-height: 100vh; padding: calc(var(--space-xl) * 1.5) var(--space-md) var(--space-lg); align-items: center;">
  
  <div class="asymmetric-item left glass-container animate-fade-in delay-100" style="z-index: 2;">
    <div style="font-size: var(--text-sm); font-family: var(--font-mono); color: var(--color-text-muted); margin-bottom: var(--space-sm); letter-spacing: 0.1em; text-transform: uppercase;">
      Hands-Off Growth Systems
    </div>
    
    <h1 style="font-size: var(--text-5xl); margin-bottom: var(--space-md);">
      We build sales systems for <br/>
      <span class="text-accent glow-accent">design agencies.</span>
    </h1>
    
    <p style="font-size: var(--text-lg); margin-bottom: var(--space-md); color: var(--color-text-main);">
      Automate your sales and marketing processes for effortless execution.
    </p>

    <p style="font-size: var(--text-base); margin-bottom: var(--space-lg);">
      The process of hiring in-house can be slow, expensive, and often results in a lack of expertise in creating optimal systems from the beginning. By partnering with us, you gain access to a team of award-winning world-class automation experts ready to run your project immediately.
    </p>

    <div>
      <a href="https://calendly.com/andrickjohn-l0n9/30min" target="_blank" class="btn">
        Let's Chat
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>
  </div>

  <div class="asymmetric-item right animate-fade-in delay-500" style="position: relative; display: flex; justify-content: flex-end;">
    <!-- Abstract Visual Density Element -->
    <div style="position: absolute; width: 100%; height: 100%; background: radial-gradient(circle at right, rgba(79, 70, 229, 0.15) 0%, transparent 60%); z-index: 0; pointer-events: none;"></div>
    
    <div style="width: 80%; height: 600px; border: 1px solid rgba(255,255,255,0.05); border-radius: 2px; position: relative; z-index: 1; overflow: hidden;">
      <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div style="position: absolute; top: 30%; left: 10%; width: 50%; height: 50px; background: rgba(79, 70, 229, 0.2); filter: blur(20px);"></div>
      <div style="position: absolute; bottom: 20%; right: 20%; width: 30%; height: 30%; border: 1px solid var(--color-accent); transform: rotate(15deg) skew(-10deg);"></div>
      <div style="position: absolute; top: 10%; right: 10%; font-family: var(--font-mono); font-size: var(--text-xs); color: rgba(255,255,255,0.2);">X: 412. Y: 890</div>
    </div>
  </div>

</section>
