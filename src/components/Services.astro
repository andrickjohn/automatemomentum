---
---
<section id="services" style="padding: var(--space-2xl) var(--space-md); position: relative;">
  <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 1px; height: 100%; background: linear-gradient(180deg, transparent, rgba(255,255,255,0.05), transparent); z-index: 0;"></div>
  
  <div style="max-width: 1000px; margin: 0 auto; position: relative; z-index: 1;">
    <h2 style="font-size: var(--text-4xl); margin-bottom: var(--space-2xl); text-align: center;">
      Operational <span class="text-accent">Systems.</span>
    </h2>

    <div style="display: flex; flex-direction: column; gap: var(--space-xl);">
      
      <div class="glass-container animate-fade-in delay-100" style="margin-left: 0; margin-right: auto; max-width: 700px;">
        <div style="font-family: var(--font-mono); color: var(--color-accent); font-size: var(--text-xs); letter-spacing: 0.2em; margin-bottom: var(--space-sm);">SYST-01</div>
        <h3 style="font-size: var(--text-3xl);">Sales Systems</h3>
        <div style="width: 50px; height: 1px; background: var(--color-accent); margin: var(--space-md) 0;"></div>
        <p style="font-size: var(--text-lg); color: var(--color-text-main);">Automated, AI driven lead acquisition systems that book sales meetings directly on your calendar.</p>
      </div>

      <div class="glass-container animate-fade-in delay-300" style="margin-left: auto; margin-right: 0; max-width: 700px; text-align: right;">
        <div style="font-family: var(--font-mono); color: var(--color-accent); font-size: var(--text-xs); letter-spacing: 0.2em; margin-bottom: var(--space-sm);">SYST-02</div>
        <h3 style="font-size: var(--text-3xl);">Marketing Systems</h3>
        <div style="width: 50px; height: 1px; background: var(--color-accent); margin: var(--space-md) 0 0 auto;"></div>
        <p style="font-size: var(--text-lg); color: var(--color-text-main);">Finished, hands-off inbound marketing systems that nurture leads autonomously.</p>
      </div>

      <div class="glass-container animate-fade-in delay-500" style="margin-left: 0; margin-right: auto; max-width: 700px;">
        <div style="font-family: var(--font-mono); color: var(--color-accent); font-size: var(--text-xs); letter-spacing: 0.2em; margin-bottom: var(--space-sm);">SYST-03</div>
        <h3 style="font-size: var(--text-3xl);">Project Management</h3>
        <div style="width: 50px; height: 1px; background: var(--color-accent); margin: var(--space-md) 0;"></div>
        <p style="font-size: var(--text-lg); color: var(--color-text-main);">Take advantage of best practice, high ROI project management systems used by top performing companies.</p>
      </div>

    </div>
  </div>
</section>
